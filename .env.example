# LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_your_key_here
LANGSMITH_PROJECT=risk-assessment-agent

# Model provider — pick one (or more)
GOOGLE_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Search
TAVILY_API_KEY=your_tavily_api_key_here

# Vertex AI (optional — set MODEL_PROVIDER=vertex to use)
# GOOGLE_APPLICATION_CREDENTIALS=./vertexCred.json

# Model selection: "gemini", "openai", or "vertex" (default: gemini)
MODEL_PROVIDER=gemini
